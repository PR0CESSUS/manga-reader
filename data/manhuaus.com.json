{
  "match": "manhuaus\\.com\\/manga\\/(?<slug>.*?)\\/(?:chapter-(?<episode>\\d+))?",
  "url": "https://manhuaus.com/manga/${slug}/",
  "first": "ul.main > li:last-child > a",
  "next": ".btn.next_page",
  "chapters": ".wp-manga-chapter a",
  "title": ".post-title h1",
  "image": "a[href=\"${url}\"] img"
}
